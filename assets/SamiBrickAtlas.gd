static func region(sprite_name: StringName) -> Rect2i:
    return FRAMES[String(sprite_name)]

static func make_atlas_texture(sprite_name: StringName) -> AtlasTexture:
    var texture := load(ATLAS_PATH)
    var atlas_texture := AtlasTexture.new()
    atlas_texture.atlas = texture
    atlas_texture.region = FRAMES[String(sprite_name)]
    return atlas_texture
